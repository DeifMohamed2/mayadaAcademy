<script>
(function () {
  function wireGroupCascade(centerNames, gradeTypeOptions, groupTimes) {
    const centerEl = document.getElementById('centerName');
    const gradeEl = document.getElementById('Grade');
    const gradeTypeEl = document.getElementById('gradeType');
    const groupTimeEl = document.getElementById('groupTime');
    if (!centerEl || !gradeEl || !gradeTypeEl || !groupTimeEl) return;

    centerEl.addEventListener('change', () => {
      const centerName = centerEl.value;
      gradeEl.innerHTML = '<option value="" selected>Select Grade</option>';
      gradeTypeEl.innerHTML = '<option value="" selected>Type</option>';
      groupTimeEl.innerHTML = '<option value="" selected>Group Time</option>';
      if (centerNames[centerName]) {
        centerNames[centerName].forEach((center) => {
          const option = document.createElement('option');
          option.value = center.value;
          option.textContent = center.text;
          gradeEl.appendChild(option);
        });
      }
    });

    gradeEl.addEventListener('change', function () {
      const selectedGrade = this.value;
      gradeTypeEl.innerHTML = '<option value="" selected>Type</option>';
      groupTimeEl.innerHTML = '<option value="" selected>Group Time</option>';
      if (gradeTypeOptions[selectedGrade]) {
        gradeTypeOptions[selectedGrade].forEach((opt) => {
          const option = document.createElement('option');
          option.value = opt.value;
          option.textContent = opt.text;
          gradeTypeEl.appendChild(option);
        });
      }
      updateGroupTimes();
    });

    function updateGroupTimes() {
      const selectedCenter = centerEl.value;
      const selectedGrade = gradeEl.value;
      const selectedGradeType = gradeTypeEl.value;
      groupTimeEl.innerHTML = '<option value="" selected>Group Time</option>';
      if (!groupTimes[selectedCenter]) return;
      if (!groupTimes[selectedCenter][selectedGrade]) return;
      if (!groupTimes[selectedCenter][selectedGrade][selectedGradeType]) return;
      groupTimes[selectedCenter][selectedGrade][selectedGradeType].forEach(
        (group) => {
          const option = document.createElement('option');
          option.value = group.value;
          option.textContent = group.text;
          groupTimeEl.appendChild(option);
        },
      );
    }

    gradeTypeEl.addEventListener('change', updateGroupTimes);
  }

  document.addEventListener('DOMContentLoaded', async function () {
    const centerEl = document.getElementById('centerName');
    if (!centerEl) return;

    try {
      const res = await fetch('/groupOptions');
      const data = await res.json();
      if (!res.ok) {
        console.error('groupOptions:', data.message || res.status);
        return;
      }
      const { centers, centerNames, gradeTypeOptions, groupTimes } = data;

      const first = centerEl.querySelector('option[value=""]');
      centerEl.innerHTML = '';
      if (first) centerEl.appendChild(first.cloneNode(true));
      else {
        const o = document.createElement('option');
        o.value = '';
        o.textContent = 'اختر السنتر';
        centerEl.appendChild(o);
      }
      (centers || []).forEach((c) => {
        const opt = document.createElement('option');
        opt.value = c;
        opt.textContent = c;
        centerEl.appendChild(opt);
      });

      wireGroupCascade(centerNames, gradeTypeOptions, groupTimes);

      const gradeEl = document.getElementById('Grade');
      const gradeTypeEl = document.getElementById('gradeType');
      const groupTimeEl = document.getElementById('groupTime');
      const ic = centerEl.getAttribute('data-initial-center');
      const ig = gradeEl && gradeEl.getAttribute('data-initial-grade');
      const it = gradeTypeEl && gradeTypeEl.getAttribute('data-initial-grade-type');
      const igt = groupTimeEl && groupTimeEl.getAttribute('data-initial-group-time');
      if (ic) {
        centerEl.value = ic;
        centerEl.dispatchEvent(new Event('change'));
      }
      if (ig && gradeEl) {
        gradeEl.value = ig;
        gradeEl.dispatchEvent(new Event('change'));
      }
      if (it && gradeTypeEl) {
        gradeTypeEl.value = it;
        gradeTypeEl.dispatchEvent(new Event('change'));
      }
      if (igt && groupTimeEl) {
        groupTimeEl.value = igt;
      }
    } catch (e) {
      console.error('Failed to load /groupOptions', e);
    }
  });
})();
</script>
