    // Tab: one message to many numbers (POST /teacher/sendSms, max 50)
    (function() {
      const bulkMsg = document.getElementById('bulkSmsMessage');
      const bulkPhones = document.getElementById('bulkSmsPhones');
      const bulkMeta = document.getElementById('bulkSmsMeta');
      const bulkCount = document.getElementById('bulkPhoneCount');
      const bulkBtn = document.getElementById('bulkSmsSubmitBtn');
      if (!bulkMsg || !bulkPhones || !bulkBtn) return;

      function updateBulkMeta() {
        const t = bulkMsg.value || '';
        const len = t.length;
        const gsm = /^[\x00-\x7F]*$/.test(t);
        const per = gsm ? 160 : 70;
        const seg = len === 0 ? 0 : len <= per ? 1 : 1 + Math.ceil((len - per) / (gsm ? 153 : 67));
        bulkMeta.textContent = 'الطول: ' + len + ' | مقاطع تقريبية: ' + seg + ' (' + (gsm ? 'GSM' : 'Unicode') + ')';
      }
      bulkMsg.addEventListener('input', updateBulkMeta);
      updateBulkMeta();

      function countBulkPhones() {
        const raw = bulkPhones.value || '';
        const list = raw.split(/[\n,;]+/).map(function(p) { return p.trim(); }).filter(Boolean);
        const uniq = [...new Set(list)];
        bulkCount.textContent = uniq.length + ' رقم';
        return uniq;
      }
      bulkPhones.addEventListener('input', countBulkPhones);
      countBulkPhones();

      function showBulkAlert(type, text) {
        const el = document.getElementById('bulkSmsAlert');
        if (!el) return;
        el.textContent = text;
        el.className = 'message-alert ' + type;
        el.style.display = 'block';
        setTimeout(function() { el.style.display = 'none'; }, 6000);
      }

      bulkBtn.addEventListener('click', async function() {
        if (!SMS_PAGE_ENABLED) {
          showBulkAlert('error', 'الإرسال معطّل');
          return;
        }
        clearGlobalSmsErrors();
        const message = bulkMsg.value.trim();
        if (!message) {
          showBulkAlert('error', 'أدخل نص الرسالة');
          return;
        }
        const list = countBulkPhones();
        if (list.length === 0) {
          showBulkAlert('error', 'أضف رقماً واحداً على الأقل');
          return;
        }
        if (list.length > SMS_BULK_MAX) {
          showBulkAlert('error', 'الحد ' + SMS_BULK_MAX + ' رقم');
          return;
        }
        setSmsOverlay(true);
        bulkBtn.disabled = true;
        try {
          const res = await fetch('/teacher/sendSms', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: message, phones: list.join('\n') }),
          });
          const data = await res.json().catch(function() { return {}; });
          const panel = document.getElementById('bulkSmsResults');
          const card = document.getElementById('bulkSmsResultCard');
          if (panel) panel.style.display = 'block';
          if (card) {
            card.classList.remove('error', 'success');
            card.classList.add(data.success ? 'success' : 'error');
          }
          document.getElementById('bulkStatSent').textContent = data.sent != null ? data.sent : '—';
          document.getElementById('bulkStatFailed').textContent = data.failed != null ? data.failed : '—';
          document.getElementById('bulkStatTotal').textContent = data.total != null ? data.total : '—';
          const seg = data.segmentEstimate;
          document.getElementById('bulkSegInfo').textContent = seg
            ? ('المقاطع: ' + (seg.segments != null ? seg.segments : seg) + ' — ' + (seg.encoding || ''))
            : '';
          const ew = document.getElementById('bulkErrorsWrap');
          const elist = document.getElementById('bulkErrorsList');
          if (ew && elist && data.errors && data.errors.length) {
            ew.style.display = 'block';
            elist.innerHTML = '';
            data.errors.slice(0, 20).forEach(function(e) {
              const li = document.createElement('li');
              li.textContent = (e.phone || '') + ' — ' + (e.message || '');
              elist.appendChild(li);
            });
          } else if (ew) {
            ew.style.display = 'none';
          }
          if (res.ok && data.success) {
            showBulkAlert('success', data.messageSummaryAr || 'تم الإرسال');
          } else {
            showBulkAlert('error', data.message || data.messageSummaryAr || 'فشل الإرسال');
            if (data.errors && data.errors.length) {
              showGlobalSmsErrors(data.errors);
            }
          }
        } catch (e) {
          showBulkAlert('error', e.message || 'خطأ');
        } finally {
          setSmsOverlay(false);
          bulkBtn.disabled = !SMS_PAGE_ENABLED;
        }
      });
    })();
  </script>
</body>

</html>